# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — contains API keys
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ============================================================
# Vault — all user-generated data, not for the repo
# ============================================================
vault/raw/
vault/wiki/
vault/chat/
vault/index.md
vault/log.md
vault/SCHEMA.md

# Vault settings — contains API keys
vault/.settings.json

# Keep empty vault directory
!vault/.gitkeep

# ============================================================
# Agent / IDE / tooling files
# ============================================================
.pi/
.agents/
.hermes/
.claude/
.cursorskills/

# Build plans and internal docs (not for the public repo)
BUILD_PLAN.md
